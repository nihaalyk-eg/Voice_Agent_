    {"id":"confirm1t","type":"text","x":230,"y":910,"width":540,"height":80,"text":"CONFIRMATION GATE\nRead back summary: address, apt, issue, master key, phone\nAsk: \"Is all of this correct?\"\nWAIT for: joo/kyllä/yes/correct/ja/stämmer/täsmälleen\nAnything else → correct & re-confirm","fontSize":12,"fontFamily":1,"textAlign":"left","strokeColor":"#c0392b","fillStyle":"solid","roughness":0},

