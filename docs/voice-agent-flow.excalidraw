    {"id":"gather1t","type":"text","x":270,"y":773,"width":460,"height":74,"text":"GATHER — one question per turn, wait for answer\nQ1: What is the problem?\nQ2: Apartment or common area?\nQ3: Master key permitted?\nQ4: Special access notes? (skip if in profile)","fontSize":12,"fontFamily":1,"textAlign":"left","strokeColor":"#44337a","fillStyle":"solid","roughness":0},

