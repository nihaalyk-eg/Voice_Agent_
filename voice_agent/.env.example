# ── Azure OpenAI ───────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-key
CHAT_DEPLOYMENT_NAME=gpt-4.1-mini
OPENAI_API_VERSION=2024-10-21

# ── Azure Speech (STT + TTS) ───────────────────────────────────────────────
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=swedencentral

# ── LiveKit ────────────────────────────────────────────────────────────────
LIVEKIT_URL=ws://localhost:7880          # internal URL (agents use this)
LIVEKIT_PUBLIC_URL=ws://localhost:7880   # browser-facing URL
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_NODE_IP=127.0.0.1               # EC2: set to server private IP

# ── Agent customisation ────────────────────────────────────────────────────
AGENT_INSTRUCTIONS=You are a helpful, concise voice assistant. Keep responses short and conversational.
AGENT_VOICE=en-US-AvaNeural             # any Azure Neural voice

# ── Langfuse observability (optional) ─────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com
