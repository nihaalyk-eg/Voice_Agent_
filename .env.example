# OpenAI configuration (Standard or Azure)
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
CHAT_DEPLOYMENT_NAME=gpt-4o
PORT=3000

# Keycloak
KEYCLOAK_URL=https://your-keycloak-url
KEYCLOAK_REALM=YourRealm
KEYCLOAK_CLIENT_ID=your-backend-client-id
KEYCLOAK_CLIENT_SECRET=your_client_secret

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Valkey (Redis-compatible)
VALKEY_URL=redis://localhost:6379

# Azure Speech (STT / TTS)
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=swedencentral

# LiveKit (self-hosted or cloud)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret123456789012345678901234
# IP LiveKit advertises for WebRTC media (ICE candidates).
LIVEKIT_NODE_IP=127.0.0.1
# Public-facing LiveKit URL for the browser client (must be reachable from the browser)
LIVEKIT_PUBLIC_URL=ws://localhost:7880

# Azure OpenAI API version (required by livekit-plugins-openai for Azure)
OPENAI_API_VERSION=2024-10-21

# Langfuse observability
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_BASE_URL=https://langfuse.yourdomain.com

CUSTOMER_API_URL=http://localhost:3000

# Frontend variables (Vite)
VITE_KEYCLOAK_URL=https://your-keycloak-url
VITE_KEYCLOAK_REALM=YourRealm
VITE_KEYCLOAK_CLIENT_ID=your-frontend-client-id
